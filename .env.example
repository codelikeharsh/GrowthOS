# Required local service configuration (development-only values)
NODE_ENV=development
WEB_PORT=3000
API_PORT=3001
AI_SERVICE_PORT=8000
POSTGRES_PORT=5432
DATABASE_URL=postgresql://growthos_local:growthos_local_7f3d@localhost:5432/growthos?schema=public
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=growthos_local_minio
MINIO_SECRET_KEY=growthos_local_minio_4a9c
MINIO_BUCKET=growthos-local
MINIO_USE_SSL=false
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
API_CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
PUBLIC_WEB_URL=http://localhost:3000
LOG_LEVEL=info
OPENAPI_ENABLED=false
SESSION_COOKIE_NAME=growthos_session
CSRF_COOKIE_NAME=growthos_csrf
SESSION_TTL_HOURS=168
EMAIL_VERIFICATION_TTL_MINUTES=60
PASSWORD_RESET_TTL_MINUTES=30
INVITATION_TTL_HOURS=72
LOGIN_RATE_LIMIT=5
PASSWORD_RESET_RATE_LIMIT=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
MAIL_FROM=no-reply@growthos.local

# Optional until Phase 6; provider calls are not implemented.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Set only when PostgreSQL and Redis integration dependencies are running.
RUN_INTEGRATION_TESTS=false

{
  "name": "@growthos/config",
  "version": "0.1.0",
  "private": true,
  "description": "Validated server-side environment schemas consumed by the API and worker.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --passWithNoTests --testNamePattern=integration",
    "test:e2e": "vitest run --passWithNoTests --testNamePattern=e2e",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@growthos/eslint-config": "workspace:*",
    "@growthos/tsconfig": "workspace:*",
    "@types/node": "24.7.2",
    "eslint": "9.37.0",
    "prettier": "3.6.2",
    "rimraf": "6.0.1",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}

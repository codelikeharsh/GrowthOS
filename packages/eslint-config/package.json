{
  "name": "@growthos/eslint-config",
  "version": "0.1.0",
  "private": true,
  "description": "Role-specific flat ESLint configurations consumed by Growth OS web and Node workspaces.",
  "type": "module",
  "exports": {
    "./node": "./node.js",
    "./next": "./next.js"
  },
  "scripts": {
    "build": "node validate.js",
    "typecheck": "node validate.js",
    "test": "node validate.js",
    "test:unit": "node validate.js",
    "clean": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@eslint/js": "9.37.0",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-import-x": "4.16.1",
    "typescript-eslint": "8.46.1"
  },
  "peerDependencies": {
    "eslint": ">=9 <10",
    "typescript": ">=5.9 <6"
  }
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  DISABLED
}

enum OrganizationType {
  AGENCY
  BUSINESS
}

enum MembershipStatus {
  ACTIVE
  REVOKED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum RoleName {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum AgencyClientRelationshipStatus {
  PENDING
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum AgencyClientNoteVisibility {
  AGENCY_INTERNAL
  CLIENT_VISIBLE
}

enum BusinessLocationType {
  HEADQUARTERS
  OFFICE
  STORE
  SERVICE_AREA
  OTHER
}

enum BusinessPriceType {
  FIXED
  STARTING_FROM
  RANGE
  QUOTE_REQUIRED
  FREE
  NOT_DISPLAYED
}

enum BusinessDayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum BusinessSocialPlatform {
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  YOUTUBE
  X
  WHATSAPP
  GOOGLE_BUSINESS_PROFILE
  OTHER
}

model User {
  id                         String                     @id @default(uuid()) @db.Uuid
  email                      String                     @unique @db.VarChar(320)
  displayName                String                     @map("display_name") @db.VarChar(120)
  passwordHash               String                     @map("password_hash") @db.VarChar(255)
  status                     UserStatus                 @default(PENDING_VERIFICATION)
  emailVerifiedAt            DateTime?                  @map("email_verified_at") @db.Timestamptz(6)
  createdAt                  DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  sessions                   Session[]
  emailVerificationTokens    EmailVerificationToken[]
  passwordResetTokens        PasswordResetToken[]
  memberships                OrganizationMember[]
  invitationsCreated         OrganizationInvitation[]   @relation("InvitationCreator")
  invitationsAccepted        OrganizationInvitation[]   @relation("InvitationAcceptor")
  auditLogs                  AuditLog[]                 @relation("AuditActor")
  membersInvited             OrganizationMember[]       @relation("MemberInviter")
  clientRelationshipsCreated AgencyClientRelationship[] @relation("RelationshipCreator")
  clientRelationshipsManaged AgencyClientRelationship[] @relation("RelationshipManager")
  agencyClientNotes          AgencyClientNote[]         @relation("NoteAuthor")

  @@map("users")
}

model Session {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  tokenHash           String    @unique @map("token_hash") @db.Char(64)
  csrfHash            String    @map("csrf_hash") @db.Char(64)
  expiresAt           DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt           DateTime? @map("revoked_at") @db.Timestamptz(6)
  lastUsedAt          DateTime  @default(now()) @map("last_used_at") @db.Timestamptz(6)
  ipAddress           String?   @map("ip_address") @db.VarChar(64)
  userAgent           String?   @map("user_agent") @db.VarChar(512)
  replacedBySessionId String?   @unique @map("replaced_by_session_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy          Session?  @relation("SessionRotation", fields: [replacedBySessionId], references: [id], onDelete: SetNull)
  replaces            Session?  @relation("SessionRotation")

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
  @@map("sessions")
}

model EmailVerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.Char(64)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.Char(64)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Organization {
  id                    String                     @id @default(uuid()) @db.Uuid
  name                  String                     @db.VarChar(160)
  slug                  String                     @unique @db.VarChar(100)
  type                  OrganizationType
  createdAt             DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  memberships           OrganizationMember[]
  invitations           OrganizationInvitation[]
  auditLogs             AuditLog[]
  agencyRelationships   AgencyClientRelationship[] @relation("AgencyRelationships")
  businessRelationships AgencyClientRelationship[] @relation("BusinessRelationships")
  businessProfile       BusinessProfile?
  businessLocations     BusinessLocation[]
  businessServices      BusinessService[]
  businessHours         BusinessHour[]
  businessSocialLinks   BusinessSocialLink[]

  @@map("organizations")
}

model AgencyClientRelationship {
  id                          String                         @id @default(uuid()) @db.Uuid
  agencyOrganizationId        String                         @map("agency_organization_id") @db.Uuid
  businessOrganizationId      String                         @map("business_organization_id") @db.Uuid
  status                      AgencyClientRelationshipStatus @default(PENDING)
  isPrimary                   Boolean                        @default(true) @map("is_primary")
  primaryAccountManagerUserId String?                        @map("primary_account_manager_user_id") @db.Uuid
  servicePlan                 String?                        @map("service_plan") @db.VarChar(120)
  startedAt                   DateTime?                      @map("started_at") @db.Timestamptz(6)
  endedAt                     DateTime?                      @map("ended_at") @db.Timestamptz(6)
  createdByUserId             String                         @map("created_by_user_id") @db.Uuid
  idempotencyKey              String?                        @map("idempotency_key") @db.VarChar(128)
  version                     Int                            @default(1)
  createdAt                   DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)
  agencyOrganization          Organization                   @relation("AgencyRelationships", fields: [agencyOrganizationId], references: [id], onDelete: Restrict)
  businessOrganization        Organization                   @relation("BusinessRelationships", fields: [businessOrganizationId], references: [id], onDelete: Restrict)
  primaryAccountManager       User?                          @relation("RelationshipManager", fields: [primaryAccountManagerUserId], references: [id], onDelete: SetNull)
  createdBy                   User                           @relation("RelationshipCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  notes                       AgencyClientNote[]

  @@unique([agencyOrganizationId, idempotencyKey])
  @@index([agencyOrganizationId, status, createdAt])
  @@index([businessOrganizationId, status])
  @@index([agencyOrganizationId, primaryAccountManagerUserId, status])
  @@map("agency_client_relationships")
}

model AgencyClientNote {
  id             String                     @id @default(uuid()) @db.Uuid
  relationshipId String                     @map("relationship_id") @db.Uuid
  authorUserId   String                     @map("author_user_id") @db.Uuid
  visibility     AgencyClientNoteVisibility
  body           String                     @db.VarChar(5000)
  editedAt       DateTime?                  @map("edited_at") @db.Timestamptz(6)
  createdAt      DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  relationship   AgencyClientRelationship   @relation(fields: [relationshipId], references: [id], onDelete: Restrict)
  author         User                       @relation("NoteAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([relationshipId, createdAt, id])
  @@index([relationshipId, visibility, createdAt])
  @@map("agency_client_notes")
}

model BusinessProfile {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @unique @map("organization_id") @db.Uuid
  legalName         String       @map("legal_name") @db.VarChar(160)
  tradeName         String?      @map("trade_name") @db.VarChar(160)
  shortDescription  String?      @map("short_description") @db.VarChar(300)
  description       String?      @db.VarChar(5000)
  industry          String?      @db.VarChar(120)
  phone             String?      @db.VarChar(32)
  email             String?      @db.VarChar(320)
  websiteDisplayUrl String?      @map("website_display_url") @db.VarChar(2048)
  timezone          String       @default("UTC") @db.VarChar(100)
  currency          String       @default("USD") @db.Char(3)
  countryCode       String       @default("US") @map("country_code") @db.Char(2)
  primaryLanguage   String       @default("en") @map("primary_language") @db.VarChar(20)
  logoFileId        String?      @map("logo_file_id") @db.Uuid
  version           Int          @default(1)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@map("business_profiles")
}

model BusinessLocation {
  id                     String               @id @default(uuid()) @db.Uuid
  businessOrganizationId String               @map("business_organization_id") @db.Uuid
  name                   String               @db.VarChar(160)
  locationType           BusinessLocationType @default(OTHER) @map("location_type")
  addressLine1           String?              @map("address_line_1") @db.VarChar(200)
  addressLine2           String?              @map("address_line_2") @db.VarChar(200)
  city                   String?              @db.VarChar(120)
  state                  String?              @db.VarChar(120)
  postalCode             String?              @map("postal_code") @db.VarChar(32)
  countryCode            String               @map("country_code") @db.Char(2)
  latitude               Decimal?             @db.Decimal(9, 6)
  longitude              Decimal?             @db.Decimal(9, 6)
  phone                  String?              @db.VarChar(32)
  email                  String?              @db.VarChar(320)
  isPrimary              Boolean              @default(false) @map("is_primary")
  isActive               Boolean              @default(true) @map("is_active")
  version                Int                  @default(1)
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  businessOrganization   Organization         @relation(fields: [businessOrganizationId], references: [id], onDelete: Restrict)

  @@index([businessOrganizationId, isActive, createdAt])
  @@map("business_locations")
}

model BusinessService {
  id                     String            @id @default(uuid()) @db.Uuid
  businessOrganizationId String            @map("business_organization_id") @db.Uuid
  name                   String            @db.VarChar(160)
  slug                   String            @db.VarChar(100)
  shortDescription       String?           @map("short_description") @db.VarChar(300)
  description            String?           @db.VarChar(5000)
  priceType              BusinessPriceType @map("price_type")
  startingPriceMinor     Int?              @map("starting_price_minor")
  maximumPriceMinor      Int?              @map("maximum_price_minor")
  currency               String?           @db.Char(3)
  durationMinutes        Int?              @map("duration_minutes")
  isActive               Boolean           @default(true) @map("is_active")
  isFeatured             Boolean           @default(false) @map("is_featured")
  displayOrder           Int               @default(0) @map("display_order")
  version                Int               @default(1)
  createdAt              DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  businessOrganization   Organization      @relation(fields: [businessOrganizationId], references: [id], onDelete: Restrict)

  @@unique([businessOrganizationId, slug])
  @@index([businessOrganizationId, isActive, displayOrder])
  @@map("business_services")
}

model BusinessHour {
  id                     String            @id @default(uuid()) @db.Uuid
  businessOrganizationId String            @map("business_organization_id") @db.Uuid
  dayOfWeek              BusinessDayOfWeek @map("day_of_week")
  opensAtMinutes         Int?              @map("opens_at_minutes")
  closesAtMinutes        Int?              @map("closes_at_minutes")
  isClosed               Boolean           @default(false) @map("is_closed")
  displayOrder           Int               @default(0) @map("display_order")
  createdAt              DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  businessOrganization   Organization      @relation(fields: [businessOrganizationId], references: [id], onDelete: Restrict)

  @@unique([businessOrganizationId, dayOfWeek, displayOrder])
  @@index([businessOrganizationId, dayOfWeek])
  @@map("business_hours")
}

model BusinessSocialLink {
  id                     String                 @id @default(uuid()) @db.Uuid
  businessOrganizationId String                 @map("business_organization_id") @db.Uuid
  platform               BusinessSocialPlatform
  url                    String                 @db.VarChar(2048)
  displayLabel           String?                @map("display_label") @db.VarChar(120)
  isPrimary              Boolean                @default(false) @map("is_primary")
  displayOrder           Int                    @default(0) @map("display_order")
  version                Int                    @default(1)
  createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  businessOrganization   Organization           @relation(fields: [businessOrganizationId], references: [id], onDelete: Restrict)

  @@index([businessOrganizationId, displayOrder])
  @@map("business_social_links")
}

model OrganizationMember {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  roleId         String           @map("role_id") @db.Uuid
  status         MembershipStatus @default(ACTIVE)
  invitedById    String?          @map("invited_by_id") @db.Uuid
  joinedAt       DateTime         @default(now()) @map("joined_at") @db.Timestamptz(6)
  revokedAt      DateTime?        @map("revoked_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)
  invitedBy      User?            @relation("MemberInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([userId, status])
  @@index([organizationId, status])
  @@map("organization_members")
}

model OrganizationInvitation {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  email          String           @db.VarChar(320)
  roleId         String           @map("role_id") @db.Uuid
  tokenHash      String           @unique @map("token_hash") @db.Char(64)
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime         @map("expires_at") @db.Timestamptz(6)
  invitedById    String           @map("invited_by_id") @db.Uuid
  acceptedById   String?          @map("accepted_by_id") @db.Uuid
  acceptedAt     DateTime?        @map("accepted_at") @db.Timestamptz(6)
  revokedAt      DateTime?        @map("revoked_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)
  invitedBy      User             @relation("InvitationCreator", fields: [invitedById], references: [id], onDelete: Restrict)
  acceptedBy     User?            @relation("InvitationAcceptor", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([organizationId, status, expiresAt])
  @@index([email, status])
  @@index([expiresAt])
  @@map("organization_invitations")
}

model Role {
  id          String                   @id @default(uuid()) @db.Uuid
  name        RoleName                 @unique
  description String                   @db.VarChar(255)
  createdAt   DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  memberships OrganizationMember[]
  invitations OrganizationInvitation[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique @db.VarChar(120)
  description String           @db.VarChar(255)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  actorUserId    String?       @map("actor_user_id") @db.Uuid
  action         String        @db.VarChar(100)
  targetType     String?       @map("target_type") @db.VarChar(80)
  targetId       String?       @map("target_id") @db.Uuid
  requestId      String?       @map("request_id") @db.VarChar(128)
  ipAddress      String?       @map("ip_address") @db.VarChar(64)
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor          User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

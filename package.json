{
  "name": "zero2one-growth-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "preinstall": "node scripts/check-runtime.cjs",
    "dev": "node --env-file=.env ./node_modules/turbo/bin/turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write . && turbo run format",
    "format:check": "prettier --check . && turbo run format:check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "db:generate": "node --env-file=.env scripts/run-command.cjs pnpm --filter @growthos/db generate",
    "db:validate": "node --env-file=.env scripts/run-command.cjs pnpm --filter @growthos/db validate",
    "db:migrate": "node --env-file=.env scripts/run-command.cjs pnpm --filter @growthos/db migrate",
    "db:migrate:deploy": "node --env-file=.env scripts/run-command.cjs pnpm --filter @growthos/db migrate:deploy",
    "db:migrate:status": "node --env-file=.env scripts/run-command.cjs pnpm --filter @growthos/db migrate:status",
    "db:studio": "node --env-file=.env scripts/run-command.cjs pnpm --filter @growthos/db studio",
    "railway:build:web": "pnpm --filter @growthos/web... build && node scripts/package-next-standalone.cjs",
    "railway:start:web": "pnpm --filter @growthos/web start",
    "railway:build:api": "pnpm --filter @growthos/api... build",
    "railway:start:api": "pnpm --filter @growthos/api start",
    "railway:prisma:deploy": "pnpm --filter @growthos/db migrate:deploy",
    "railway:build:worker": "pnpm --filter @growthos/worker... build",
    "railway:start:worker": "pnpm --filter @growthos/worker start",
    "railway:build:ai-service": "pnpm --filter @growthos/ai-service build:production",
    "railway:start:ai-service": "pnpm --filter @growthos/ai-service start:production",
    "secrets:generate": "node scripts/generate-production-secret.cjs",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "clean": "turbo run clean && rimraf .turbo coverage",
    "prepare": "node scripts/check-runtime.cjs"
  },
  "devDependencies": {
    "prettier": "3.6.2",
    "rimraf": "6.0.1",
    "turbo": "2.5.8",
    "typescript": "5.9.3"
  }
}

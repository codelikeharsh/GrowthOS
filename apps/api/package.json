{
  "name": "@growthos/api",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS/Fastify API boundary and dependency health shell for Growth OS.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run src/dependencies.integration.test.ts",
    "test:e2e": "vitest run src/app.test.ts",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@fastify/cors": "11.1.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/swagger": "9.5.2",
    "@fastify/swagger-ui": "5.2.3",
    "@growthos/config": "workspace:*",
    "@growthos/db": "workspace:*",
    "@growthos/logger": "workspace:*",
    "@nestjs/common": "11.1.6",
    "@nestjs/core": "11.1.6",
    "@nestjs/platform-fastify": "11.1.6",
    "@nestjs/swagger": "11.2.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "fastify": "5.4.0",
    "ioredis": "5.8.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@growthos/eslint-config": "workspace:*",
    "@growthos/tsconfig": "workspace:*",
    "@types/node": "24.7.2",
    "eslint": "9.37.0",
    "prettier": "3.6.2",
    "rimraf": "6.0.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}

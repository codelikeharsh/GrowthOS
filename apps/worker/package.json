{
  "name": "@growthos/worker",
  "version": "0.1.0",
  "private": true,
  "description": "BullMQ worker process lifecycle, Redis health, and safe job logging foundation.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --env-file-if-exists=../../.env ../../scripts/run-command.cjs vitest run",
    "test:unit": "node --env-file-if-exists=../../.env ../../scripts/run-command.cjs vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "node --env-file-if-exists=../../.env ../../scripts/run-command.cjs vitest run src/redis.integration.test.ts",
    "test:e2e": "node --env-file-if-exists=../../.env ../../scripts/run-command.cjs vitest run --passWithNoTests --testNamePattern=e2e",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@growthos/config": "workspace:*",
    "@growthos/db": "workspace:*",
    "@growthos/logger": "workspace:*",
    "bullmq": "5.61.2",
    "ioredis": "5.8.1"
  },
  "devDependencies": {
    "@growthos/eslint-config": "workspace:*",
    "@growthos/tsconfig": "workspace:*",
    "@types/node": "24.7.2",
    "eslint": "9.37.0",
    "prettier": "3.6.2",
    "rimraf": "6.0.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}

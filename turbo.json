{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "env": [
        "AI_PROVIDER",
        "AI_SERVICE_URL",
        "AI_SERVICE_PORT",
        "API_CORS_ORIGINS",
        "API_PORT",
        "DATABASE_URL",
        "LOG_LEVEL",
        "MAIL_FROM",
        "NEXT_PUBLIC_API_URL",
        "NODE_ENV",
        "OPENAI_API_KEY",
        "OPENAI_MODEL",
        "OPENAPI_ENABLED",
        "PASSWORD_RESET_RATE_LIMIT",
        "PASSWORD_RESET_TTL_MINUTES",
        "PUBLIC_WEB_URL",
        "SMTP_HOST",
        "SMTP_PASSWORD",
        "SMTP_PORT",
        "SMTP_SECURE",
        "SMTP_USER",
        "REDIS_URL",
        "SESSION_COOKIE_NAME",
        "SESSION_TTL_HOURS",
        "CSRF_COOKIE_NAME",
        "EMAIL_VERIFICATION_TTL_MINUTES",
        "INVITATION_TTL_HOURS",
        "LOGIN_RATE_LIMIT",
        "AUTH_RATE_LIMIT_WINDOW_SECONDS",
        "WEB_APP_URL",
        "WEB_PORT"
      ],
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URL",
        "REDIS_URL",
        "RUN_INTEGRATION_TESTS",
        "SMTP_HOST",
        "SMTP_PORT",
        "PUBLIC_WEB_URL"
      ],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": [
        "DATABASE_URL",
        "REDIS_URL",
        "RUN_INTEGRATION_TESTS",
        "SMTP_HOST",
        "SMTP_PORT",
        "PUBLIC_WEB_URL"
      ],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false,
      "env": [
        "DATABASE_URL",
        "REDIS_URL",
        "NEXT_PUBLIC_API_URL",
        "SMTP_HOST",
        "SMTP_PORT",
        "PUBLIC_WEB_URL"
      ],
      "outputs": []
    },
    "@growthos/ai-service#build": { "outputs": [] },
    "@growthos/eslint-config#build": { "outputs": [] },
    "@growthos/tsconfig#build": { "outputs": [] },
    "clean": {
      "cache": false
    }
  }
}
